<?xml version="1.0" encoding="UTF-8"?>
<!--
  CycloneDDS configuration for low-latency quadruped control.

  Features:
    - Shared Memory (SHM) enabled for zero-copy intra-host communication
    - Multicast disabled to reduce network overhead on the robot
    - Optimized for small, high-frequency messages (Float32MultiArray @ 50-500 Hz)

  Usage:
    source config/setup_cyclonedds.sh   # before launching any ROS 2 node
-->
<CycloneDDS xmlns="https://cdds.io/config" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="https://cdds.io/config https://raw.githubusercontent.com/eclipse-cyclonedds/cyclonedds/master/etc/cyclonedds.xsd">
  <Domain id="any">
    <General>
      <Interfaces>
        <NetworkInterface autodetermine="true" priority="default"
                         multicast="false"/>
      </Interfaces>
      <AllowMulticast>false</AllowMulticast>
      <MaxMessageSize>65500B</MaxMessageSize>
    </General>

    <!-- Shared Memory transport: zero-copy when pub/sub on the same host -->
    <SharedMemory>
      <Enable>true</Enable>
      <LogLevel>info</LogLevel>
    </SharedMemory>

    <Internal>
      <Watermarks>
        <WhcHigh>500kB</WhcHigh>
      </Watermarks>
      <WriterLingerDuration>0s</WriterLingerDuration>
    </Internal>

    <Tracing>
      <Verbosity>warning</Verbosity>
      <OutputFile>stderr</OutputFile>
    </Tracing>
  </Domain>
</CycloneDDS>
